# --- Supabase (SOLO servidor, NO usar prefijo NEXT_PUBLIC_) ---
# URL de tu proyecto Supabase (Project Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# service_role key (Project Settings > API > service_role secret)
# ¡CRÍTICO! Nunca la expongas con NEXT_PUBLIC_, nunca la subas a git.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Autenticación de la app (single-user) ---
# Contraseña de acceso al dashboard. Cámbiala por algo fuerte.
APP_PASSWORD=cambia-esta-clave-por-una-segura

# Secreto para firmar la cookie de sesión (JWT). Genera uno con:
# openssl rand -base64 48
SESSION_SECRET=genera-un-secreto-aleatorio-de-al-menos-32-caracteres

# --- IA para el módulo de Finanzas (Groq) ---
# Consigue tu key en https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Opcional: verifica el nombre del modelo vigente en
# https://console.groq.com/docs/models antes de desplegar
GROQ_MODEL=llama3-70b-8192
